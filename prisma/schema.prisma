  @@index([toBranchId])
  @@index([status])
}

enum StockTransferStatus {
  PENDING       // قيد الانتظار
  APPROVED      // تم الاعتماد
  REJECTED      // مرفوض
  IN_TRANSIT    // قيد النقل
  RECEIVED      // تم الاستلام
