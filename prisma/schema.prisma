}

model CustomerLoyalty {
  id            String   @id @default(cuid())
  customerId    String   @unique
  tierId        String?
  
  // النقاط
  totalPoints   Int      @default(0)       // إجمالي النقاط المكتسبة
  availablePoints Int    @default(0)       // النقاط المتاحة للاستخدام
  usedPoints    Int      @default(0)       // النقاط المستخدمة
  expiredPoints Int      @default(0)       // النقاط المنتهية
  
  // الإحصائيات
