// ==================== تحويلات المخزون بين الفروع ====================
model StockTransfer {
  id              String   @id @default(cuid())
  transferNumber  String   @unique
  fromBranchId    String
  toBranchId      String
  status          StockTransferStatus @default(PENDING)
  
  // معلومات إضافية
