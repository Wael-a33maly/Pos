enum ScheduleType {
  DAILY
  WEEKLY
  MONTHLY
}

enum ReportFormat {
  PDF
  EXCEL
  CSV
}

// ==================== سجل التقارير ====================
model ReportExecution {
  id              String   @id @default(cuid())
  scheduledReportId String?
  
  // معلومات التقرير
  reportType      String
  parameters      String?  // JSON
  
  // النتيجة
  status          ExecutionStatus
  fileUrl         String?
  fileSize        Int?
  recordCount     Int?
  
  // التوقيت
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  duration        Int?     // milliseconds
  
  // الأخطاء
  errorMessage    String?
  
  // من قام بالتنفيذ
  executedBy      String?
  
  createdAt       DateTime @default(now())
  
  @@index([reportType])
  @@index([status])
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ==================== العروض والخصومات التلقائية ====================
model Offer {
  id              String   @id @default(cuid())
  name            String
  nameAr          String?
  description     String?
  descriptionAr   String?
  
  // نوع العرض
  type            OfferType
  
  // القيمة
  discountType    DiscountType      // percentage, fixed
  discountValue   Float             @default(0)
  maxDiscount     Float?            // أقصى قيمة للخصم
  
  // الفترة الزمنية
  startDate       DateTime
  endDate         DateTime
  
  // شروط العرض
  minPurchase     Float?            // الحد الأدنى للمشتريات
  minQuantity     Int?              // الحد الأدنى للكمية
  maxUses         Int?              // أقصى عدد استخدامات
  maxUsesPerUser  Int?              // أقصى استخدامات لكل عميل
  currentUses     Int               @default(0)
  
  // المنتجات المشمولة
  appliesTo       ApplyType         @default(ALL)
  productIds      String?           // JSON array
  categoryIds     String?           // JSON array
  brandIds        String?           // JSON array
  
  // الفروع
  branchIds       String?           // JSON array, null = all branches
  
  // أولوية العرض
  priority        Int               @default(0)
  
  // هل يمكن دمجه مع عروض أخرى
  isCombinable    Boolean           @default(false)
  
  // العملاء المستهدفون
  targetCustomers CustomerTarget    @default(ALL)
  tierIds         String?           // JSON array for loyalty tiers
  
  // أيام الأسبوع
  activeDays      String?           // JSON array [0,1,2,3,4,5,6]
  
  // أوقات العمل
  startTime       String?           // HH:mm
  endTime         String?           // HH:mm
  
  // الحالة
  isActive        Boolean           @default(true)
  isAutoApplied   Boolean           @default(true)  // تطبيق تلقائي بدون كود
  
  // كود الخصم (اختياري)
  code            String?           @unique
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  items           OfferItem[]
  usages          OfferUsage[]
  
  @@index([type])
  @@index([isActive])
  @@index([startDate, endDate])
}

enum OfferType {
  PRODUCT_DISCOUNT     // خصم على منتج
  CATEGORY_DISCOUNT    // خصم على فئة
  CART_DISCOUNT        // خصم على السلة
  BUY_X_GET_Y          // اشتري X واحصل على Y
  BUNDLE               // حزمة منتجات
  FLASH_SALE           // عرض سريع
  SEASONAL             // عرض موسمي
  LOYALTY              // عرض للعملاء المميزين
  FIRST_PURCHASE       // أول عملية شراء
}

enum DiscountType {
  PERCENTAGE           // نسبة مئوية
  FIXED                // مبلغ ثابت
}

enum ApplyType {
  ALL                  // جميع المنتجات
  PRODUCTS             // منتجات محددة
  CATEGORIES           // فئات محددة
  BRANDS               // براندات محددة
}

enum CustomerTarget {
  ALL                  // جميع العملاء
  NEW                  // عملاء جدد
  RETURNING            // عملاء عائدون
  LOYALTY_TIERS        // مستويات ولاء محددة
}

model OfferItem {
  id              String   @id @default(cuid())
  offerId         String
  productId       String
  variationId     String?
  
  // خصم خاص للمنتج
  discountValue   Float?
  discountType    DiscountType?
  
  // للعروض من نوع Buy X Get Y
  requiredQty     Int      @default(1)
  freeQty         Int      @default(0)
  freeProductId   String?
  freeVariationId String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  offer           Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  
  @@index([offerId])
  @@index([productId])
}

model OfferUsage {
  id              String   @id @default(cuid())
  offerId         String
  invoiceId       String
  customerId      String?
  userId          String
  
  // تفاصيل الاستخدام
  discountAmount  Float    @default(0)
  itemsCount      Int      @default(0)
  
  // الكود المستخدم
  codeUsed        String?
  
  createdAt       DateTime @default(now())
  
  offer           Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  
  @@index([offerId])
  @@index([customerId])
  @@index([invoiceId])
}

// ==================== الجرد الدوري ====================
model InventoryCount {
  id              String   @id @default(cuid())
  countNumber     String   @unique
  branchId        String
  
  // نوع الجرد
  countType       CountType
  status          CountStatus @default(DRAFT)
  
  // الفترة
  scheduledDate   DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  
  // المستخدمين
  createdBy       String
  approvedBy      String?
  completedBy     String?
  
  // الملخص
  totalItems      Int      @default(0)
  countedItems    Int      @default(0)
  discrepancyItems Int     @default(0)
  totalValue      Float    @default(0)
  discrepancyValue Float   @default(0)
  
  // ملاحظات
  notes           String?
  approvalNotes   String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  items           InventoryCountItem[]
  
  @@index([branchId])
  @@index([status])
}

enum CountType {
  FULL            // جرد شامل
  PARTIAL         // جرد جزئي
  CYCLE           // جرد دوري
  SPOT            // جرد مفاجئ
}

enum CountStatus {
  DRAFT           // مسودة
  SCHEDULED       // مجدول
  IN_PROGRESS     // جاري
  PENDING_REVIEW  // في انتظار المراجعة
  APPROVED        // معتمد
  COMPLETED       // مكتمل
  CANCELLED       // ملغي
}

model InventoryCountItem {
  id              String   @id @default(cuid())
  countId         String
  productId       String
  variationId     String?
  
  // الكميات
  systemQty       Float    @default(0)    // الكمية في النظام
  countedQty      Float?                  // الكمية الفعلية
  discrepancyQty  Float?                  // الفرق
  
  // الأسعار
  unitCost        Float    @default(0)
  discrepancyValue Float   @default(0)
  
  // الحالة
  status          ItemCountStatus @default(PENDING)
  
  // من قام بالعد
  countedBy       String?
  countedAt       DateTime?
  
  // ملاحظات
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  count           InventoryCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  
  @@index([countId])
  @@index([productId])
  @@unique([countId, productId, variationId])
}

enum ItemCountStatus {
  PENDING         // في الانتظار
  COUNTED         // تم العد
  VERIFIED        // تم التحقق
  ADJUSTED        // تم التعديل
}

model InventoryAdjustment {
  id              String   @id @default(cuid())
  adjustmentNumber String  @unique
  branchId        String
  
  // السبب
  reason          AdjustmentReason
  reference       String?    // رقم مرجعي
  notes           String?
  
  // القيم
  totalItems      Int      @default(0)
  totalValue      Float    @default(0)
  
  // المستخدمين
  createdBy       String
  approvedBy      String?
  
  // التواريخ
  adjustmentDate  DateTime @default(now())
  approvedAt      DateTime?
  
  status          AdjustmentStatus @default(PENDING)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  items           InventoryAdjustmentItem[]
  
  @@index([branchId])
  @@index([status])
}

enum AdjustmentReason {
  INVENTORY_COUNT  // جرد
  DAMAGE           // تلف
  THEFT            // سرقة
  EXPIRY           // انتهاء صلاحية
  RETURN_TO_SUPPLIER // إرجاع للمورد
  SAMPLE           // عينات
  INTERNAL_USE     // استخدام داخلي
  ERROR_CORRECTION // تصحيح خطأ
  OTHER            // أخرى
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model InventoryAdjustmentItem {
  id              String   @id @default(cuid())
  adjustmentId    String
  productId       String
  variationId     String?
  
  // الكميات
  previousQty     Float    @default(0)
  adjustmentQty   Float    @default(0)
  newQty          Float    @default(0)
  
  // القيم
  unitCost        Float    @default(0)
  adjustmentValue Float    @default(0)
  
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  adjustment      InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  
  @@index([adjustmentId])
  @@index([productId])
}

// ==================== نظام المشتريات ====================
model PurchaseOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  supplierId      String
  branchId        String?
  
  // الحالة
  status          PurchaseStatus @default(DRAFT)
  
  // التواريخ
  orderDate       DateTime @default(now())
  expectedDate    DateTime?
  receivedDate    DateTime?
  
  // القيم
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  shippingCost    Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  
  // المستخدمين
  createdBy       String
  approvedBy      String?
  receivedBy      String?
  
  // ملاحظات
  notes           String?
  supplierNotes   String?
  internalNotes   String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  items           PurchaseOrderItem[]
  payments        PurchasePayment[]
  
  @@index([supplierId])
  @@index([status])
}

enum PurchaseStatus {
  DRAFT           // مسودة
  PENDING         // في الانتظار
  APPROVED        // معتمد
  ORDERED         // تم الطلب
  PARTIAL         // استلام جزئي
  RECEIVED        // تم الاستلام
  CANCELLED       // ملغي
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String?
  variationId     String?
  
  // المنتج (يمكن إضافة منتج جديد)
  productName     String
  productBarcode  String?
  sku             String?
  
  // الكميات
  orderedQty      Float    @default(0)
  receivedQty     Float    @default(0)
  pendingQty      Float    @default(0)
  
  // الأسعار
  unitCost        Float    @default(0)
  subtotal        Float    @default(0)
  taxRate         Float    @default(0)
  taxAmount       Float    @default(0)
  discountPercent Float    @default(0)
  totalAmount     Float    @default(0)
  
  // تاريخ الاستلام المتوقع
  expectedDate    DateTime?
  
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  order           PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@index([orderId])
  @@index([productId])
}

model PurchasePayment {
  id              String   @id @default(cuid())
  orderId         String
  paymentMethodId String?
  
  amount          Float    @default(0)
  reference       String?
  notes           String?
  paymentDate     DateTime @default(now())
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  order           PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@index([orderId])
}

// ==================== استلام المشتريات ====================
model GoodsReceipt {
  id              String   @id @default(cuid())
  receiptNumber   String   @unique
  purchaseOrderId String?
  supplierId      String
  branchId        String?
  
  // الحالة
  status          ReceiptStatus @default(DRAFT)
  
  // التواريخ
  receiptDate     DateTime @default(now())
  
  // القيم
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  totalAmount     Float    @default(0)
  
  // المستخدمين
  receivedBy      String
  approvedBy      String?
  
  // ملاحظات
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  items           GoodsReceiptItem[]
  
  @@index([purchaseOrderId])
  @@index([supplierId])
  @@index([status])
}

enum ReceiptStatus {
  DRAFT
  PENDING
  APPROVED
  CANCELLED
}

model GoodsReceiptItem {
  id              String   @id @default(cuid())
  receiptId       String
  productId       String?
  variationId     String?
  purchaseOrderItemId String?
  
  // المنتج
  productName     String
  productBarcode  String?
  
  // الكميات
  orderedQty      Float    @default(0)
  receivedQty     Float    @default(0)
  acceptedQty     Float    @default(0)
  rejectedQty     Float    @default(0)
  
  // سبب الرفض
  rejectionReason String?
  
  // الأسعار
  unitCost        Float    @default(0)
  totalAmount     Float    @default(0)
  
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  receipt         GoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  
  @@index([receiptId])
  @@index([productId])
}
