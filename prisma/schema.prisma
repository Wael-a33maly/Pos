  @@index([customerId])
  @@index([type])
}

enum LoyaltyTransactionType {
  EARN          // كسب نقاط
  REDEEM        // استبدال نقاط
  EXPIRE        // انتهاء صلاحية
  BONUS         // نقاط مكافأة
