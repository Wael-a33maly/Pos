// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== الفروع ====================
model Branch {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  address     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       User[]
  products    Product[]
  invoices    Invoice[]
  shifts      Shift[]
  expenses    Expense[]
  customers   Customer[]
  suppliers   Supplier[]
  inventory   Inventory[]
}

// ==================== الأدوار المخصصة ====================
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  nameAr      String
  description String?
  color       String   @default("#3b82f6")
  isSystem    Boolean  @default(false)  // للأدوار الافتراضية
  isActive    Boolean  @default(true)
  priority    Int      @default(0)      // أولوية الدور (أعلى = صلاحيات أكثر)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       User[]   @relation("UserRole")
  permissions RolePermission[]
}

// ==================== الصلاحيات المتاحة ====================
model SystemPermission {
  id          String   @id @default(cuid())
  module      String   // dashboard, users, products, invoices, expenses, reports, settings, shifts, customers, suppliers, pos, accounts
  action      String   // view, create, edit, delete, export, import, approve, manage
  name        String   // الاسم بالإنجليزية
  nameAr      String   // الاسم بالعربية
  description String?
  group       String   // مجموعة الصلاحية للتنظيم
  groupAr     String   // اسم المجموعة بالعربية
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  rolePermissions RolePermission[]
  userPermissions UserPermission[]
  
  @@unique([module, action])
}

// ==================== صلاحيات الدور ====================
model RolePermission {
  id             String   @id @default(cuid())
  roleId         String
  permissionId   String
  allowed        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  role           Role              @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission     SystemPermission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@unique([roleId, permissionId])
}

// ==================== المستخدمين ====================
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  nameAr      String?
  phone       String?
  avatar      String?
  role        String   @default("USER")  // للتوافق مع الكود القديم: SUPER_ADMIN, BRANCH_ADMIN, USER
  roleId      String?  // الدور المخصص من نظام الأدوار الجديد
  branchId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  branch      Branch?  @relation(fields: [branchId], references: [id])
  roleRef     Role?    @relation("UserRole", fields: [roleId], references: [id])
  shifts      Shift[]
  invoices    Invoice[]
  userPermissions UserPermission[]
  notifications Notification[]
  auditLogs   AuditLog[]
  closedShifts Shift[] @relation("ShiftCloser")
}

// ==================== صلاحيات المستخدم الفردية ====================
model UserPermission {
  id             String   @id @default(cuid())
  userId         String
  permissionId   String
  allowed        Boolean  @default(true)
  grantedBy      String?  // من منح الصلاحية
  grantedAt      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission     SystemPermission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@unique([userId, permissionId])
}

// ==================== الإعدادات ====================
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== طرق الدفع ====================
model PaymentMethod {
  id          String   @id @default(cuid())
  name        String
  nameAr      String
  code        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  payments    Payment[]
}

// ==================== العملات ====================
model Currency {
  id          String   @id @default(cuid())
  name        String
  nameAr      String
  code        String   @unique
  symbol      String
  decimalPlaces Int    @default(2)
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== الفئات ====================
model Category {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  parentId    String?
  image       String?
  color       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
}

// ==================== البراندات ====================
model Brand {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  logo        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  products    Product[]
}

// ==================== الشركات الموردة ====================
model Supplier {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  phone       String?
  email       String?
  address     String?
  taxNumber   String?
  notes       String?
  branchId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  branch      Branch?  @relation(fields: [branchId], references: [id])
  products    Product[]
}

// ==================== العملاء ====================
model Customer {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  phone       String?
  email       String?
  address     String?
  taxNumber   String?
  notes       String?
  branchId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  branch      Branch?  @relation(fields: [branchId], references: [id])
  invoices    Invoice[]
  loyalty     CustomerLoyalty?
}

// ==================== المنتجات ====================
model Product {
  id            String   @id @default(cuid())
  barcode       String   @unique
  sku           String?
  name          String
  nameAr        String?
  description   String?
  categoryId    String?
  brandId       String?
  supplierId    String?
  branchId      String?
  costPrice     Float    @default(0)
  sellingPrice  Float    @default(0)
  wholesalePrice Float?
  minStock      Int      @default(0)
  maxStock      Int?
  unit          String   @default("piece")
  image         String?
  hasVariants   Boolean  @default(false)
  isStockTracked Boolean @default(true)  // هل المنتج مخزني (يتقيد بالمخزون)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  category      Category?  @relation(fields: [categoryId], references: [id])
  brand         Brand?     @relation(fields: [brandId], references: [id])
  supplier      Supplier?  @relation(fields: [supplierId], references: [id])
  branch        Branch?    @relation(fields: [branchId], references: [id])
  variations    ProductVariation[]  // المتغيرات الجديدة (أسعار متعددة)
  variants      ProductVariant[]    // القديم للتوافق
  inventory     Inventory[]
  invoiceItems  InvoiceItem[]
  transferItems StockTransferItem[] // تحويلات المخزون
}

// ==================== متغيرات المنتج (النظام الجديد - أسعار متعددة) ====================
model ProductVariation {
  id            String   @id @default(cuid())
  productId     String
  
  // سعر هذا المتغير
  price         Float    @default(0)
  
  // اسم اختياري للتمييز (مثل "سعر الجملة" أو "عرض خاص")
  name          String?
  
  // باركود فريد يتبع المنتج الأصلي
  barcode       String   @unique
  
  // التحكم في المخزون
  stock         Int      @default(0)
  isStockTracked Boolean @default(true)  // هل هذا المتغير مخزني
  
  // الحالة
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  invoiceItems  InvoiceItem[]
  
  @@index([productId])
  @@index([barcode])
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  name        String
  nameAr      String?
  sku         String?
  barcode     String?
  costPrice   Float    @default(0)
  sellingPrice Float   @default(0)
  stock       Int      @default(0)
  attributes  String?  // JSON string for variant attributes like {"color": "red", "size": "XL"}
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]
}

// ==================== المخزون ====================
model Inventory {
  id          String   @id @default(cuid())
  productId   String
  branchId    String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt
  
  product     Product  @relation(fields: [productId], references: [id])
  branch      Branch   @relation(fields: [branchId], references: [id])
  
  @@unique([productId, branchId])
}

// ==================== الفواتير ====================
model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  branchId        String
  userId          String
  customerId      String?
  shiftId         String?
  status          InvoiceStatus @default(COMPLETED)
  paymentStatus   PaymentStatus @default(PAID)
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  changeAmount    Float    @default(0)
  notes           String?
  isReturn        Boolean  @default(false)
  originalInvoiceId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  branch          Branch     @relation(fields: [branchId], references: [id])
  user            User       @relation(fields: [userId], references: [id])
  customer        Customer?  @relation(fields: [customerId], references: [id])
  shift           Shift?     @relation(fields: [shiftId], references: [id])
  items           InvoiceItem[]
  payments        Payment[]
  returns         Invoice[]  @relation("InvoiceReturns")
  originalInvoice Invoice?   @relation("InvoiceReturns", fields: [originalInvoiceId], references: [id])
}

enum InvoiceStatus {
  PENDING
  COMPLETED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model InvoiceItem {
  id            String   @id @default(cuid())
  invoiceId     String
  productId     String?
  variantId     String?   // للنظام القديم
  variationId   String?   // للنظام الجديد (متغيرات الأسعار)
  productName   String
  quantity      Float    @default(1)
  unitPrice     Float    @default(0)
  costPrice     Float    @default(0)
  discountAmount Float   @default(0)
  taxAmount     Float    @default(0)
  totalAmount   Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  
  invoice       Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product       Product?        @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  variation     ProductVariation? @relation(fields: [variationId], references: [id])
}

model Payment {
  id              String   @id @default(cuid())
  invoiceId       String
  paymentMethodId String
  amount          Float    @default(0)
  reference       String?  // Reference number for payment
  notes           String?
  createdAt       DateTime @default(now())
  
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
}

// ==================== الورديات ====================
model Shift {
  id              String   @id @default(cuid())
  branchId        String
  userId          String
  startTime       DateTime @default(now())
  endTime         DateTime?
  openingCash     Float    @default(0)
  closingCash     Float?
  expectedCash    Float?
  totalSales      Float    @default(0)
  totalReturns    Float    @default(0)
  totalExpenses   Float    @default(0)
  totalPayments   Float    @default(0)
  status          ShiftStatus @default(OPEN)
  closureType     ShiftClosureType?
  closureReason   String?
  forceClosedBy   String?
  sessionRevoked  Boolean  @default(false)
  notes           String?
  closedBy        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  branch          Branch    @relation(fields: [branchId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
  invoices        Invoice[]
  expenses        Expense[]
  closedByUser    User?     @relation("ShiftCloser", fields: [closedBy], references: [id])
}

enum ShiftStatus {
  OPEN
  CLOSED
  FORCE_CLOSED
}

enum ShiftClosureType {
  NORMAL
  FORCED
  AUTO
  BRANCH_ALL
}

// ==================== المصروفات ====================
model ExpenseCategory {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  parentId    String?  // للفئات الفرعية
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  parent      ExpenseCategory?  @relation("ExpenseCategoryHierarchy", fields: [parentId], references: [id])
  children    ExpenseCategory[] @relation("ExpenseCategoryHierarchy")
  expenses    Expense[]
}

model Expense {
  id          String   @id @default(cuid())
  branchId    String
  shiftId     String?
  categoryId  String
  amount      Float
  description String?
  userId      String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  branch      Branch           @relation(fields: [branchId], references: [id])
  shift       Shift?           @relation(fields: [shiftId], references: [id])
  category    ExpenseCategory  @relation(fields: [categoryId], references: [id])
}

// ==================== الإشعارات ====================
model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  titleAr     String?
  message     String
  messageAr   String?
  type        String
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== سجل التدقيق ====================
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  module      String
  recordId    String?
  oldData     String?  // JSON
  newData     String?  // JSON
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  user        User?    @relation(fields: [userId], references: [id])
}

// ==================== إعدادات الطباعة ====================
model PrintTemplate {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  type        String   // invoice, barcode, report
  paperSize   String   @default("A4")
  width       Int?
  height      Int?
  template    String   // HTML template
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== إعدادات الباركود ====================
model BarcodeSetting {
  id              String   @id @default(cuid())
  name            String
  paperWidth      Int      @default(80)
  paperHeight     Int      @default(50)
  labelWidth      Int      @default(70)
  labelHeight     Int      @default(40)
  columns         Int      @default(3)
  rows            Int      @default(8)
  showProductName Boolean  @default(true)
  showPrice       Boolean  @default(true)
  showBarcode     Boolean  @default(true)
  showSku         Boolean  @default(false)
  fontSize        Int      @default(10)
  barcodeHeight   Int      @default(20)
  isActive        Boolean  @default(true)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== الحسابات ====================
model Account {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  nameAr      String?
  type        AccountType
  parentId    String?
  balance     Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  parent      Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[] @relation("AccountHierarchy")
  lines       JournalEntryLine[]
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model JournalEntry {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  reference   String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  lines       JournalEntryLine[]
}

model JournalEntryLine {
  id          String   @id @default(cuid())
  entryId     String
  accountId   String
  debit       Float    @default(0)
  credit      Float    @default(0)
  description String?
  
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account     Account      @relation(fields: [accountId], references: [id])
}

// ==================== ملخصات المبيعات ====================
model DailySalesSummary {
  id            String   @id @default(cuid())
  branchId      String
  date          DateTime
  totalSales    Float    @default(0)
  totalReturns  Float    @default(0)
  totalDiscount Float    @default(0)
  totalTax      Float    @default(0)
  totalProfit   Float    @default(0)
  invoiceCount  Int      @default(0)
  customerCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([branchId, date])
}

model HourlySalesSummary {
  id            String   @id @default(cuid())
  branchId      String
  date          DateTime
  hour          Int      // 0-23
  totalSales    Float    @default(0)
  invoiceCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([branchId, date, hour])
}

model ProductSalesSummary {
  id            String   @id @default(cuid())
  productId     String
  branchId      String
  date          DateTime
  quantitySold  Float    @default(0)
  totalRevenue  Float    @default(0)
  totalProfit   Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([productId, branchId, date])
}

// ==================== تفاصيل إغلاق الوردية ====================
model ShiftCloseDetail {
  id                String   @id @default(cuid())
  shiftId           String   @unique
  userId            String
  closingNumber     Int      // مسلسل فريد لكل مستخدم
  closingDate       DateTime @default(now())
  
  // الملخص المالي
  openingCash       Float    @default(0)
  cashSales         Float    @default(0)
  cardSales         Float    @default(0)
  otherPayments     Float    @default(0)
  totalSales        Float    @default(0)
  totalReturns      Float    @default(0)
  totalDiscounts    Float    @default(0)
  totalExpenses     Float    @default(0)
  expectedCash      Float    @default(0)
  actualCash        Float    @default(0)
  cashDifference    Float    @default(0)
  
  // ملخص الفواتير
  totalInvoices     Int      @default(0)
  completedInvoices Int      @default(0)
  cancelledInvoices Int      @default(0)
  returnInvoices    Int      @default(0)
  
  // ملخص المنتجات
  totalItems        Int      @default(0)
  totalQuantity     Float    @default(0)
  
  notes             String?
  createdAt         DateTime @default(now())
}

model ShiftTransaction {
  id              String   @id @default(cuid())
  shiftId         String
  type            String   // OPENING, CASH_SALE, CARD_SALE, RETURN, EXPENSE, CASH_IN, CASH_OUT, CLOSING
  amount          Float    @default(0)
  reference       String?  // رقم الفاتورة أو المرجع
  paymentMethod   String?
  description     String?
  createdAt       DateTime @default(now())
}

// ==================== التقارير المحفوظة ====================
model SavedReport {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  type        String   // sales, products, shifts, profits, customers
  dateRange   String   // today, week, month, year, custom
  startDate   DateTime?
  endDate     DateTime?
  filters     String?  // JSON
  data        String   // JSON - البيانات المحفوظة
  userId      String
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReportSetting {
  id              String   @id @default(cuid())
  userId          String
  reportType      String
  defaultRange    String   @default("week")
  showChart       Boolean  @default(true)
  showTable       Boolean  @default(true)
  columns         String?  // JSON array of visible columns
  sortBy          String?
  sortOrder       String   @default("desc")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([userId, reportType])
}

model DashboardSetting {
  id              String   @id @default(cuid())
  userId          String   @unique
  layout          String?  // JSON for widget positions
  widgets         String?  // JSON array of enabled widgets
  refreshInterval Int      @default(300) // seconds
  showSales       Boolean  @default(true)
  showOrders      Boolean  @default(true)
  showProducts    Boolean  @default(true)
  showCustomers   Boolean  @default(true)
  showCharts      Boolean  @default(true)
  showLowStock    Boolean  @default(true)
  showRecentSales Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ExportTemplate {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  type        String   // csv, excel, pdf
  module      String   // sales, products, invoices, etc.
  columns     String   // JSON array of column configs
  format      String?  // JSON for custom formatting
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== إعدادات نقطة البيع ====================
model POSSetting {
  id                    String   @id @default(cuid())
  userId                String   @unique
  
  // عرض عناصر بطاقة المنتج
  showProductName       Boolean  @default(true)
  showProductBarcode    Boolean  @default(true)
  showProductPrice      Boolean  @default(true)
  showProductImage      Boolean  @default(true)
  showProductStock      Boolean  @default(false)
  
  // إعدادات الخطوط
  productNameFontSize   Int      @default(14)  // px
  productNameColor      String   @default("#000000")
  productPriceFontSize  Int      @default(16)  // px
  productPriceColor     String   @default("#16a34a") // green-600
  productBarcodeFontSize Int     @default(10)  // px
  productBarcodeColor   String   @default("#6b7280") // gray-500
  
  // إعدادات السلة
  cartItemFontSize      Int      @default(14)
  cartTotalFontSize     Int      @default(18)
  
  // إعدادات العرض
  cardBorderWidth       Int      @default(2)   // px
